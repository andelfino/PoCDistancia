# Copiar este archivo como .env en esta misma carpeta (backend/).
# Al arrancar, Spring Boot carga .env si existe; si TOMTOM_API_KEY ya está
# definida en el sistema o en el IDE, esa valor tiene prioridad sobre .env.
# NUNCA subir el valor real de la API Key al repositorio.

# API Key de TomTom (obtener en https://developer.tomtom.com/)
TOMTOM_API_KEY=tu_api_key_aqui
