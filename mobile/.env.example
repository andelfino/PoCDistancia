# Copiar este archivo como .env y ajustar la URL según el entorno.
# NUNCA incluir API Keys de TomTom u otros servicios aquí.
# Solo se expone la URL base del backend propio.

# ── Expo Web (misma máquina) ─────────────────────────────
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# ── Emulador Android ─────────────────────────────────────
# 10.0.2.2 es el alias que Android asigna al host de la PC.
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080

# ── Dispositivo físico / misma red Wi-Fi ─────────────────
# Reemplazar con la IP LAN de la PC donde corre el backend.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.0.X:8080

EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
